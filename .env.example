# Garmin Connect credentials (used only for the initial login; tokens are then
# cached under DATA_DIR/garth so they aren't needed on every start).
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-password

# Where all persistent state lives (sqlite db, raw .fit files, token cache).
# Inside Docker this is /data (mounted volume). Override for native dev.
DATA_DIR=/data
